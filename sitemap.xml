---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>{{ '/' | absolute_url }}</loc>
  </url>
  <url>
    <loc>{{ '/resume.html' | absolute_url }}</loc>
  </url>
  <url>
    <loc>{{ '/projects.html' | absolute_url }}</loc>
  </url>
  <url>
    <loc>{{ '/blog.html' | absolute_url }}</loc>
  </url>
  <url>
    <loc>{{ '/gallery.html' | absolute_url }}</loc>
  </url>
  <url>
    <loc>{{ '/contact.html' | absolute_url }}</loc>
  </url>
  {% for project in site.projects %}
  <url>
    <loc>{{ project.url | absolute_url }}</loc>
  </url>
  {% endfor %}
  {% for post in site.posts %}
  <url>
    <loc>{{ post.url | absolute_url }}</loc>
  </url>
  {% endfor %}
</urlset>
